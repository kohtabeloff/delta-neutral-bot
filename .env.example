# Telegram
TELEGRAM_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Стратегия
MIN_APR_THRESHOLD=100
SCAN_INTERVAL_SECONDS=60
POSITION_SIZE_USD=100        # размер одной ноги в USD

# Hyperliquid (для одиночных позиций, Фаза 1)
HYPERLIQUID_PRIVATE_KEY=
WALLET_ADDRESS=

# Backpack Exchange (для торговли, Фаза 2)
# Создай API ключ на backpack.exchange → Settings → API Keys
# api_key = Base64-encoded Ed25519 public key
# api_secret = Base64-encoded Ed25519 private key seed
BACKPACK_API_KEY=
BACKPACK_API_SECRET=

# Lighter DEX (для торговли, Фаза 2)
# Создай API ключ на lighter.xyz → Settings → API Keys
# Установи: pip install lighter-sdk
LIGHTER_API_PRIVATE_KEY=
LIGHTER_API_KEY_INDEX=2      # индекс ключа (обычно 2 или 3)
LIGHTER_ACCOUNT_INDEX=0      # индекс твоего аккаунта на Lighter

# Variational DEX (для пары Variational + Extended)
# Как получить: войди на omni.variational.io → F12 → Application → Cookies → vr-token
VARIATIONAL_TOKEN=           # vr-token из браузера (обновлять при истечении)
VARIATIONAL_WALLET=          # твой EVM адрес 0x...

# Extended Exchange (для пары Variational + Extended)
# Создай API ключ на extended.exchange → API Management
# Установи: pip install x10-python-trading-starknet
EXTENDED_API_KEY=
EXTENDED_PUBLIC_KEY=
EXTENDED_PRIVATE_KEY=
EXTENDED_VAULT_ID=0          # vault id из API Management
